CVE-2025-47906  # os/exec: unexpected paths from LookPath
CVE-2025-47907  # database/sql: Postgres scan race condition
CVE-2025-47912  # net/url: insufficient validation bracketed IPv6
CVE-2025-4673   # net/http: sensitive headers cross-origin redirect
CVE-2025-58183  # archive/tar: unbounded allocation GNU sparse map
CVE-2025-58185  # encoding/asn1: memory exhaustion

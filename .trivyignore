CVE-2025-61723  # encoding/pem: quadratic complexity invalid inputs
CVE-2025-61724  # net/textproto: excessive CPU ReadResponse
CVE-2025-61725  # net/mail: excessive CPU ParseAddress
CVE-2025-61726  # net/url: memory exhaustion query parameters
CVE-2025-61727  # crypto/x509: excluded subdomain wildcard SANs
CVE-2025-61728  # archive/zip: excessive CPU building archive index
CVE-2025-61729  # crypto/x509: DoS via crafted certificate
CVE-2025-61730  # TLS 1.3: multiple messages in records
CVE-2025-68121  # crypto/tls: unexpected session resumption

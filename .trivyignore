# ── golang.org/x/net — dépendance transitive de esbuild, non exposée ─────────
CVE-2025-22870  # golang.org/x/net/httpproxy: HTTP Proxy bypass via IPv6 Zone IDs

# ── node-tar / tar — embarqués dans le runtime npm, pas dans node_modules app ─
CVE-2026-26960  # node-tar: arbitrary file read/write hardlink
CVE-2026-29786  # node-tar: hardlink path traversal drive-relative
CVE-2026-31802  # tar: file overwrite drive-relative symlink

# ── minimatch — embarqué dans npm CLI, pas dans node_modules app ──────────────
CVE-2026-26996  # minimatch: DoS specially crafted glob
CVE-2026-27903  # minimatch: DoS unbounded recursive backtracking
CVE-2026-27904  # minimatch: DoS catastrophic backtracking

# ── zlib Alpine — bibliothèque système, untgz utility non utilisé par l'app ───
CVE-2026-22184  # zlib: arbitrary code execution buffer overflow in untgz

# ── picomatch / brace-expansion — embarqués dans npm CLI, pas dans node_modules app ─
CVE-2026-33671  # picomatch: ReDoS via crafted extglob patterns in npm's tinyglobby
CVE-2026-33672  # picomatch: method injection via POSIX bracket expressions in npm's tinyglobby
CVE-2026-33750  # brace-expansion: DoS via zero step value in npm's dependencies

# ── esbuild — serveur de dev uniquement, jamais exposé en production ──────────
